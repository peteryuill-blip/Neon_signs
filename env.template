# ─── NEON SIGNS — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Database ─────────────────────────────────────────────────────────────────
# MySQL/TiDB connection string
DATABASE_URL=mysql://user:password@host:4000/dbname?ssl={"rejectUnauthorized":true}

# ─── Session Security ─────────────────────────────────────────────────────────
# Long random string used to sign session JWTs
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-random-secret-here

# ─── Local Authentication ─────────────────────────────────────────────────────
# Bcrypt hash of the admin password
# Generate with: node scripts/hash-password.mjs
ADMIN_PASSWORD_HASH=$2b$12$...

# ─── Cloudflare R2 Storage ────────────────────────────────────────────────────
# Your Cloudflare account ID (found in dashboard URL)
R2_ACCOUNT_ID=your-account-id

# R2 API token credentials (create at Cloudflare Dashboard → R2 → Manage API tokens)
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key

# R2 bucket name
R2_BUCKET_NAME=neon-signs

# Public URL for the bucket (enable public access or use custom domain)
# e.g. https://pub-xxxxxxxxxxxx.r2.dev  OR  https://files.yourdomain.com
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ─── LLM (Optional) ───────────────────────────────────────────────────────────
# OpenAI API key — only needed if you use LLM features
OPENAI_API_KEY=sk-...

# Optional: override the OpenAI API base URL (e.g. for Azure OpenAI or proxies)
# OPENAI_API_BASE_URL=https://api.openai.com

# ─── Google Maps (Optional) ───────────────────────────────────────────────────
# Only needed if map features are used
# GOOGLE_MAPS_API_KEY=AIza...

# ─── Runtime ──────────────────────────────────────────────────────────────────
# Set automatically by Railway; override locally if needed
# PORT=3000
NODE_ENV=production
